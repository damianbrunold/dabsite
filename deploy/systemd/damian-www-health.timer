[Unit]
Description=Run damian_www health probe every minute

[Timer]
# Wait a minute after boot before the first probe so the app has time
# to bind its socket. Then probe every minute.
OnBootSec=60s
OnUnitActiveSec=60s
AccuracySec=15s
Unit=damian-www-health.service

[Install]
WantedBy=timers.target
